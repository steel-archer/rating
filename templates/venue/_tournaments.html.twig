<turbo-frame id="venue-tournaments">
    <div class="card card-wide">
        <h2>{{ 'nav.tournaments'|trans }}</h2>
        <table aria-label="{{ 'nav.tournaments'|trans }}">
            <thead>
                <tr>
                    <th>{{ 'common.tournament'|trans }}</th>
                    <th>{{ 'common.date'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for t in tournaments %}
                    <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}">
                        <td><a href="{{ path('tournament_show', {id: t.tournamentId}) }}" data-turbo-frame="_top" data-turbo="false">{{ t.tournamentName }}</a></td>
                        <td>{{ t.playedAt ? t.playedAt|date('d.m.Y') : '—' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {{ include('_pagination.html.twig', {paginationRoute: 'venue_tournaments', paginationParams: {id: venueId}}) }}
    </div>
</turbo-frame>
