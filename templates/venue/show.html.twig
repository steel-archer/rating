{% extends 'base.html.twig' %}

{% block title %}{{ venue.name }} — {{ 'nav.venues'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span><a href="{{ path('venue_index') }}">{{ 'nav.venues'|trans }}</a></span><span>{{ venue.name }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ venue.name }}</h1>
    <div class="meta"><span>{{ venue.townName }}</span></div>

    {% if venue.representatives is not empty %}
        <div class="card">
            <h2>{{ 'venue.representatives'|trans }}</h2>
            <ul class="representatives-list">
                {% for rep in venue.representatives %}
                    <li><a href="{{ path('player_show', {id: rep.player.id}) }}">{{ rep.player.fullName }}</a></li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if venue.tournamentCount > 0 %}
        <turbo-frame id="venue-tournaments" src="{{ path('venue_tournaments', {id: venue.id}) }}">
            <p>{{ 'common.loading_tournaments'|trans }}</p>
        </turbo-frame>
    {% endif %}
{% endblock %}
