<turbo-frame id="claim-search">
    <div class="search-form">
        <form action="{{ path('player_claim_search') }}" method="get">
            <div class="search-row">
                <input type="text" name="lastName" value="{{ filters.lastName ?? '' }}" placeholder="{{ 'player.last_name'|trans }}" class="search-input">
                <input type="text" name="firstName" value="{{ filters.firstName ?? '' }}" placeholder="{{ 'player.first_name'|trans }}" class="search-input">
                <input type="text" name="patronymic" value="{{ filters.patronymic ?? '' }}" placeholder="{{ 'player.patronymic'|trans }}" class="search-input">
                <div class="suggest-wrapper" data-suggest-url="{{ path('api_towns_suggest') }}">
                    <input type="text" data-suggest-input value="{{ townName ?? '' }}" placeholder="{{ 'common.town'|trans }}" class="search-input" autocomplete="off">
                    <input type="hidden" name="townId" data-suggest-hidden value="{{ filters.townId ?? '' }}">
                    <div class="suggest-dropdown" data-suggest-dropdown></div>
                </div>
                <button type="submit" class="search-btn">{{ 'common.search'|trans }}</button>
            </div>
        </form>
    </div>

    {% if players is not empty %}
        <table aria-label="{{ 'player_claim.existing_title'|trans }}">
            <thead>
                <tr>
                    <th>{{ 'player.full_name'|trans }}</th>
                    <th>{{ 'common.town'|trans }}</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for p in players %}
                    <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}">
                        <td>{{ p.fullName }}</td>
                        <td>{{ p.townName ?? '' }}</td>
                        <td>
                            <button type="button" class="btn-link" data-player-claim-existing="{{ p.id }}">{{ 'player_claim.select'|trans }}</button>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {% include '_pagination.html.twig' with {paginationRoute: 'player_claim_search', paginationParams: filters} %}
    {% elseif filters is not empty %}
        <p>{{ 'common.not_found'|trans }}</p>
    {% endif %}
</turbo-frame>
