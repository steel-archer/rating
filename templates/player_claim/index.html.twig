{% extends 'base.html.twig' %}

{% block title %}{{ 'player_claim.title'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span>{{ 'player_claim.title'|trans }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ 'player_claim.title'|trans }}</h1>

    <div class="card">
        <div class="form-group">
            <label>{{ 'player_claim.your_email'|trans }}</label>
            <input type="email" value="{{ app.user.email }}" readonly class="search-input">
        </div>
        <div class="form-group">
            <label for="claim-telegram">{{ 'contact.telegram'|trans }} <span class="hint-inline">({{ 'contact.optional'|trans }})</span></label>
            <input type="text" id="claim-telegram" name="telegram" value="{{ app.user.telegram }}" placeholder="{{ 'contact.telegram.placeholder'|trans }}" class="search-input" maxlength="32">
        </div>
        <div class="form-group">
            <label for="claim-facebook">{{ 'contact.facebook'|trans }} <span class="hint-inline">({{ 'contact.optional'|trans }})</span></label>
            <input type="text" id="claim-facebook" name="facebook" value="{{ app.user.facebook }}" placeholder="{{ 'contact.facebook.placeholder'|trans }}" class="search-input" maxlength="50">
        </div>
        <div class="form-group">
            <label for="claim-phone">{{ 'contact.phone'|trans }} <span class="hint-inline">({{ 'contact.optional'|trans }})</span></label>
            <input type="tel" id="claim-phone" name="phone" value="{{ app.user.phone }}" placeholder="{{ 'contact.phone.placeholder'|trans }}" class="search-input" maxlength="20">
        </div>
        <p class="hint">{{ 'contact.visibility_warning'|trans }}</p>
    </div>

    <div class="cards-row">
        <div class="card">
            <h2>{{ 'player_claim.existing_title'|trans }}</h2>
            <p>{{ 'player_claim.existing_description'|trans }}</p>

            <turbo-frame id="claim-search">
                <div class="search-form">
                    <form action="{{ path('player_claim_search') }}" method="get">
                        <div class="search-row">
                            <input type="text" name="lastName" value="" placeholder="{{ 'player.last_name'|trans }}" class="search-input">
                            <input type="text" name="firstName" value="" placeholder="{{ 'player.first_name'|trans }}" class="search-input">
                            <input type="text" name="patronymic" value="" placeholder="{{ 'player.patronymic'|trans }}" class="search-input">
                            <div class="suggest-wrapper" data-suggest-url="{{ path('api_towns_suggest') }}">
                                <input type="text" data-suggest-input value="" placeholder="{{ 'common.town'|trans }}" class="search-input" autocomplete="off">
                                <input type="hidden" name="townId" data-suggest-hidden value="">
                                <div class="suggest-dropdown" data-suggest-dropdown></div>
                            </div>
                            <button type="submit" class="search-btn">{{ 'common.search'|trans }}</button>
                        </div>
                    </form>
                </div>
            </turbo-frame>
        </div>

        <div class="card">
            <h2>{{ 'player_claim.new_title'|trans }}</h2>
            <p>{{ 'player_claim.new_description'|trans }}</p>

            <form id="player-claim-new-form" data-url="{{ path('player_claim_new') }}">
                <div class="form-group">
                    <input type="text" name="lastName" required placeholder="{{ 'player.last_name'|trans }} *" value="{{ app.user.lastName }}" class="search-input">
                </div>
                <div class="form-group">
                    <input type="text" name="firstName" required placeholder="{{ 'player.first_name'|trans }} *" value="{{ app.user.firstName }}" class="search-input">
                </div>
                <div class="form-group">
                    <input type="text" name="patronymic" placeholder="{{ 'player.patronymic'|trans }}" class="search-input">
                </div>
                <div class="form-group">
                    <div class="suggest-wrapper" data-suggest-url="{{ path('api_towns_suggest') }}">
                        <input type="text" data-suggest-input placeholder="{{ 'common.town'|trans }} *" class="search-input" autocomplete="off" required>
                        <input type="hidden" name="townId" data-suggest-hidden>
                        <div class="suggest-dropdown" data-suggest-dropdown></div>
                    </div>
                </div>
                <button type="submit" class="search-btn">{{ 'player_claim.submit'|trans }}</button>
                <span id="claim-new-status" class="save-status" hidden></span>
            </form>
        </div>
    </div>
{% endblock %}
