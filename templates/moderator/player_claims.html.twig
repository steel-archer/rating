{% extends 'base.html.twig' %}

{% block title %}{{ 'moderator.player_claims'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span>{{ 'moderator.player_claims'|trans }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ 'moderator.player_claims'|trans }}</h1>

    {% for message in app.flashes('error') %}
        <div class="flash-error">{{ message }}</div>
    {% endfor %}

    {% if claims is empty %}
        <p>{{ 'moderator.no_pending_claims'|trans }}</p>
    {% else %}
        <table aria-label="{{ 'moderator.player_claims'|trans }}">
            <thead>
                <tr>
                    <th>{{ 'moderator.player_claim_user'|trans }}</th>
                    <th>{{ 'moderator.player_claim_type'|trans }}</th>
                    <th>{{ 'moderator.player_claim_details'|trans }}</th>
                    <th>{{ 'common.town'|trans }}</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for claim in claims %}
                    <tr>
                        <td>{{ claim.userEmail }}</td>
                        <td>
                            {% if claim.isNew %}
                                {{ 'moderator.player_claim_new'|trans }}
                            {% else %}
                                {{ 'moderator.player_claim_existing'|trans }}
                            {% endif %}
                        </td>
                        <td>
                            {% if claim.isNew %}
                                {{ claim.lastName }} {{ claim.firstName ?? '' }} {{ claim.patronymic ?? '' }}
                            {% else %}
                                {{ include('_player_link.html.twig', {playerId: claim.playerId, playerName: claim.playerName, hasUser: claim.playerHasUser}, with_context: false) }}
                            {% endif %}
                        </td>
                        <td>
                            {% if claim.isNew %}
                                <div class="suggest-wrapper claim-town-wrapper" data-suggest-url="{{ path('api_towns_suggest') }}" data-claim-id="{{ claim.id }}">
                                    <input type="text"
                                           data-suggest-input
                                           class="search-input search-input-sm"
                                           autocomplete="off"
                                           value="{{ claim.townName ?? '' }}"
                                           {% if claim.townIsNew %}data-town-is-new{% endif %}>
                                    <div class="suggest-dropdown" data-suggest-dropdown></div>
                                </div>
                            {% else %}
                                {{ claim.townName ?? '' }}
                            {% endif %}
                        </td>
                        <td class="claim-actions">
                            <button type="button" class="btn btn-approve" data-player-claim-approve="{{ claim.id }}">{{ 'moderator.approve'|trans }}</button>
                            <button type="button" class="btn btn-reject" data-player-claim-reject="{{ claim.id }}">{{ 'moderator.reject'|trans }}</button>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
