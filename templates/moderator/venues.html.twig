{% extends 'base.html.twig' %}

{% block title %}{{ 'moderator.venues'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span>{{ 'moderator.venues'|trans }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ 'moderator.venues'|trans }}</h1>

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message|trans }}</div>
    {% endfor %}

    {% if venues is empty %}
        <p class="empty-state">{{ 'moderator.no_venue_claims'|trans }}</p>
    {% else %}
        <div class="card card-wide">
            <table aria-label="{{ 'moderator.venues'|trans }}">
                <thead>
                    <tr>
                        <th>{{ 'common.name'|trans }}</th>
                        <th>{{ 'common.town'|trans }}</th>
                        <th>{{ 'venue.representative'|trans }}</th>
                        <th>{{ 'common.date'|trans }}</th>
                        <th>{{ 'tournament.my.actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for venue in venues %}
                        <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}" data-venue-id="{{ venue.id }}">
                            <td>{{ venue.name }}</td>
                            <td>{{ venue.town.name }}</td>
                            <td>
                                {% if venue.createdBy and venue.createdBy.player %}
                                    <a href="{{ path('player_show', {id: venue.createdBy.player.id}) }}">{{ venue.createdBy.player.fullName }}</a>
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>{{ venue.createdAt|date('d.m.Y H:i') }}</td>
                            <td>
                                <button type="button" class="btn btn-approve" data-venue-approve="{{ venue.id }}">{{ 'moderator.approve'|trans }}</button>
                                <button type="button" class="btn btn-reject" data-venue-reject="{{ venue.id }}">{{ 'moderator.reject'|trans }}</button>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
