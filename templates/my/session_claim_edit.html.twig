{% extends 'base.html.twig' %}

{% block title %}{{ 'session_claim.edit_title'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span><a href="{{ path('my_session_claims') }}">{{ 'session_claim.my_title'|trans }}</a></span><span>{{ claim.venueName }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ 'session_claim.edit_title'|trans }}: {{ claim.venueName }}</h1>

    <div class="card">
        <dl>
            <dt>{{ 'common.tournament'|trans }}</dt>
            <dd><a href="{{ path('tournament_show', {id: claim.tournamentId}) }}">{{ claim.tournamentName }}</a></dd>
            <dt>{{ 'venue.venue'|trans }}</dt>
            <dd>{{ claim.venueName }} ({{ claim.townName }})</dd>
            <dt>{{ 'tournament.my.status'|trans }}</dt>
            <dd>
                <span class="badge {% if claim.status == 'pending' %}badge-moderation-pending{% elseif claim.status == 'approved' %}badge-moderation-approved{% else %}badge-moderation-rejected{% endif %}">{{ ('session_claim.status.' ~ claim.status)|trans }}</span>
            </dd>
        </dl>
        {% if claim.comment %}
            <div class="rejection-notice">
                <strong>{{ 'session_claim.reject_reason'|trans }}:</strong> {{ claim.comment }}
            </div>
        {% endif %}
    </div>

    {% if claim.status == 'approved' and documents is defined and documents is not empty %}
        <div class="card">
            <h2>{{ 'tournament.document.title'|trans }}</h2>
            {% for doc in documents %}
                <div class="document-entry">
                    <a href="{{ path('my_tournament_document_download', {id: doc.id}) }}" class="document-link">{{ doc.originalName }}</a>
                    <span class="document-size">({{ (doc.size / 1024)|round(0) }} KB)</span>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <div class="card">
        <form id="session-claim-edit-form" class="tournament-form" data-url="{{ path('my_session_claim_update', {id: claim.sessionId}) }}">
            <div id="save-status" class="form-error" hidden></div>
            <div class="form-group">
                <label for="edit-date">{{ 'session_claim.estimated_date'|trans }}</label>
                <input type="date" id="edit-date" name="playedAt" value="{{ claim.playedAt ? claim.playedAt|date('Y-m-d') : '' }}">
            </div>
            <div class="form-group">
                <label for="edit-teams">{{ 'session_claim.estimated_teams'|trans }}</label>
                <input type="number" id="edit-teams" name="estimatedTeams" min="1" value="{{ claim.estimatedTeams }}">
            </div>
            <div class="form-group">
                <label>{{ 'venue.host'|trans }}</label>
                <div class="officials-group" data-role="host" data-single>
                    {% if claim.hostId %}
                        <div class="official-entry">
                            <input type="hidden" name="hostId" value="{{ claim.hostId }}">
                            {{ include('_player_link.html.twig', {playerId: claim.hostId, playerName: claim.hostName, hasUser: claim.hostHasUser}, with_context: false) }}
                            <button type="button" class="btn-remove">×</button>
                        </div>
                    {% endif %}
                </div>
                <div class="suggest-wrapper" data-suggest-url="{{ path('api_players_suggest') }}">
                    <input type="text" data-suggest-input placeholder="{{ 'session_claim.add_host'|trans }}">
                    <div data-suggest-dropdown hidden></div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">{{ 'tournament.my.save'|trans }}</button>

                {% if claim.status == 'rejected' %}
                    <button type="button" class="btn btn-success" data-session-resubmit="{{ claim.sessionId }}">{{ 'session_claim.resubmit'|trans }}</button>
                {% endif %}
                {% if claim.status != 'approved' %}
                    <button type="button" class="btn btn-reject" data-session-delete="{{ claim.sessionId }}" data-redirect="{{ path('my_session_claims') }}">{{ 'session_claim.delete'|trans }}</button>
                {% endif %}
            </div>
        </form>
    </div>

    {% if canEnterResults %}
        <div class="card">
            <div class="actions-card">
                <a href="{{ path('my_session_claim_squad', {id: claim.sessionId}) }}" class="btn btn-primary">{{ 'squad.enter_squads'|trans }}</a>
                <a href="{{ path('my_session_claim_results', {id: claim.sessionId}) }}" class="btn btn-primary">{{ 'squad.enter_results'|trans }}</a>
                <a href="{{ path('my_session_claim_disputes', {id: claim.sessionId}) }}" class="btn btn-primary">{{ 'dispute.enter_disputes'|trans }}</a>
            </div>
        </div>

        {% if teams is not empty %}
            <div class="card card-wide">
                <h2>{{ 'tournament.results'|trans }}</h2>
                <table aria-label="{{ 'tournament.results'|trans }}">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th></th>
                            <th>{{ 'common.team'|trans }}</th>
                            <th>{{ 'common.town'|trans }}</th>
                            <th>{{ 'common.result'|trans }}</th>
                            <th>
                                {{ 'common.squad'|trans }}
                                <button type="button" class="btn-toggle-text" data-toggle-all-squads>{{ 'squad.show_all'|trans }}</button>
                            </th>
                            <th>{{ 'tournament.my.actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for team in teams %}
                            <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}{{ team.baseSquadCount < 3 ? ' squad-weak' : '' }}">
                                <td>{{ team.place ? (team.place == team.place|round(0) ? team.place|number_format(0) : team.place) : '—' }}</td>
                                <td class="one-time-name-hint">{% if team.oneTimeName %}<span data-tooltip="{{ 'team.base_name'|trans({'%name%': team.teamName ~ ' (' ~ team.teamTownName ~ ')'}) }}">^</span>{% endif %}</td>
                                <td>{{ include('_team_name.html.twig', {teamId: team.teamId, teamName: team.teamName, oneTimeName: team.oneTimeName}, with_context: false) }}</td>
                                <td>{{ team.teamTownName }}</td>
                                <td>{{ team.score ?? '—' }}</td>
                                <td>
                                    <button type="button" class="btn-toggle-text" data-toggle-squad>{{ 'squad.show'|trans }}</button>
                                    <div class="squad-list" hidden>
                                        {% for player in team.players %}
                                            <div class="{{ player.isBaseSquad ? 'player-base' : 'player-guest' }}">
                                                {{ include('_player_link.html.twig', {playerId: player.playerId, playerName: player.playerName, hasUser: player.hasUser}, with_context: false) }}
                                                {%- if player.isCaptain %} (к){% endif -%}
                                            </div>
                                        {% endfor %}
                                    </div>
                                </td>
                                <td>
                                    <a href="{{ path('my_session_team_edit', {id: team.sessionTeamId}) }}" class="btn btn-small">{{ 'squad.edit'|trans }}</a>
                                    <button type="button" class="btn btn-small btn-reject" data-squad-delete="{{ team.sessionTeamId }}">{{ 'squad.delete'|trans }}</button>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    {% endif %}
{% endblock %}
