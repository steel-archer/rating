{% extends 'base.html.twig' %}

{% block title %}{{ 'tournament.my.title'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span>{{ 'tournament.my.title'|trans }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ 'tournament.my.title'|trans }}</h1>

    <div class="my-tournaments-toolbar">
        <a href="{{ path('my_tournament_new') }}" class="btn btn-primary">{{ 'tournament.my.create'|trans }}</a>
    </div>

    {% if tournaments is empty %}
        <p class="empty-state">{{ 'tournament.my.empty'|trans }}</p>
    {% else %}
        <table class="my-tournaments-table">
            <thead>
                <tr>
                    <th>{{ 'common.name'|trans }}</th>
                    <th></th>
                    <th>{{ 'common.dates'|trans }}</th>
                    <th>{{ 'tournament.my.status'|trans }}</th>
                    <th>
                        <a href="{{ path('my_tournaments', {sort: sort == 'desc' ? 'asc' : 'desc'}) }}">
                            {{ 'tournament.my.last_moderation'|trans }} {{ sort == 'desc' ? '↓' : '↑' }}
                        </a>
                    </th>
                </tr>
            </thead>
            <tbody>
                {% for tournament in tournaments %}
                    {% set claim = claims[tournament.id] is defined ? claims[tournament.id] : null %}
                    <tr>
                        <td><a href="{{ path('my_tournament_edit', {id: tournament.id}) }}">{{ tournament.name }}</a></td>
                        <td>{{ include('_format_badge.html.twig', {format: tournament.format}, with_context: false) }}</td>
                        <td class="meta">
                            {% if tournament.startedAt %}
                                {{ tournament.startedAt|date('d.m.Y') }}{% if tournament.endedAt %} — {{ tournament.endedAt|date('d.m.Y') }}{% endif %}
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge badge-{{ tournament.status }}">{{ ('tournament.status.' ~ tournament.status)|trans }}</span>
                            {% if claim %}
                                <span class="badge badge-moderation-{{ claim.status }}">{{ ('tournament.moderation_status.' ~ claim.status)|trans }}</span>
                            {% endif %}
                        </td>
                        <td class="meta">
                            {% if claim and claim.resolvedAt %}
                                {{ claim.resolvedAt|date('d.m.Y H:i') }}
                            {% elseif claim %}
                                {{ claim.createdAt|date('d.m.Y H:i') }}
                            {% else %}
                                —
                            {% endif %}
                            {% if claim and claim.comment %}
                                <br><small class="moderation-comment">{{ claim.comment }}</small>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {{ include('_pagination.html.twig', {
            paginationRoute: 'my_tournaments',
            paginationParams: {sort: sort},
            page: page,
            lastPage: lastPage,
        }) }}
    {% endif %}
{% endblock %}
