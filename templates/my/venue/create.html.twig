{% extends 'base.html.twig' %}

{% block title %}{{ 'venue.my.create'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span><a href="{{ path('my_venues') }}">{{ 'venue.my.title'|trans }}</a></span><span>{{ 'venue.my.create'|trans }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ 'venue.my.create'|trans }}</h1>

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message|trans }}</div>
    {% endfor %}

    <div class="card">
        <form id="venue-create-form" class="tournament-form" data-url="{{ path('my_venue_store') }}">
            <div class="form-group">
                <label for="name">{{ 'common.name'|trans }} *</label>
                <input type="text" id="name" name="name" required>
            </div>
            <div class="form-group">
                <label for="town">{{ 'common.town'|trans }} *</label>
                <div class="suggest-wrapper" data-suggest-url="{{ path('api_towns_suggest') }}">
                    <input type="text" id="town" data-suggest-input placeholder="{{ 'common.town'|trans }}" value="{{ townName ?? '' }}" required>
                    <input type="hidden" name="townId" data-suggest-hidden value="{{ townId ?? '' }}">
                    <div data-suggest-dropdown hidden></div>
                </div>
            </div>
            <button type="submit" class="btn">{{ 'venue.my.create'|trans }}</button>
            <span id="save-status" class="save-status" hidden></span>
        </form>
    </div>
{% endblock %}
