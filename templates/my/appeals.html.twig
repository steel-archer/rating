{% extends 'base.html.twig' %}

{% block title %}{{ 'appeal.jury_title'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span>{{ 'appeal.jury_title'|trans }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ 'appeal.jury_title'|trans }}</h1>

    {% if tournaments is not empty %}
        <div class="card">
            <table aria-label="{{ 'appeal.jury_title'|trans }}">
                <thead>
                    <tr>
                        <th>{{ 'common.tournament'|trans }}</th>
                        <th>{{ 'dispute.resolved_count'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in tournaments %}
                        <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}">
                            <td><a href="{{ path('my_appeals_tournament', {id: item.tournamentId}) }}">{{ item.tournamentName }}</a></td>
                            <td>{{ item.resolved }} / {{ item.total }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="card">
            <p>{{ 'appeal.jury_empty'|trans }}</p>
        </div>
    {% endif %}
{% endblock %}
