                            <tr class="{{ rowIndex is odd ? 'row-light' : 'row-dark' }}"{{ sessionClaimId is defined ? ' data-session-claim-id="' ~ sessionClaimId ~ '"' }}{{ showActions is defined and showActions ? ' data-venue-sessions="' ~ claim.venuePlayedSessionsCount ~ '"' }}>
                                <td>
                                    <a href="{{ path('venue_show', {id: claim.venueId}) }}">{{ claim.venueName }}</a>
                                    {% if showActions is defined and showActions %}
                                        <span class="venue-sessions-count">
                                            ({{ 'session_claim.venue_sessions_count'|trans({'%count%': claim.venuePlayedSessionsCount}) }})
                                        </span>
                                        {% if claim.venuePlayedSessionsCount == 0 %}
                                            <span class="warning-badge">{{ 'session_claim.venue_no_sessions_warning'|trans }}</span>
                                        {% endif %}
                                    {% endif %}
                                </td>
                                <td>{{ claim.townName }}</td>
                                <td>{{ claim.playedAt ? claim.playedAt|date('d.m.Y') : '—' }}</td>
                                <td>{{ claim.estimatedTeams ?? '—' }}</td>
                                <td class="cell-contacts">
                                    {{ include('_player_link.html.twig', {playerId: claim.playerId, playerName: claim.playerName, hasUser: claim.playerHasUser}, with_context: false) }}
                                    {{ include('_contacts_button.html.twig', {contacts: claim.playerContacts}, with_context: false) }}
                                </td>
                                <td>
                                    {% if claim.hostId %}
                                        {{ include('_player_link.html.twig', {playerId: claim.hostId, playerName: claim.hostName, hasUser: claim.hostHasUser}, with_context: false) }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                {% if showActions is defined and showActions %}
                                    <td>
                                        <div class="moderation-actions">
                                            <input type="text" class="reject-input" placeholder="{{ 'moderator.reject_comment'|trans }}" data-session-reject-comment="{{ claim.sessionId }}">
                                            <div class="moderation-buttons">
                                                <button type="button" class="btn btn-approve" data-session-approve="{{ claim.sessionId }}">{{ 'moderator.approve'|trans }}</button>
                                                <button type="button" class="btn btn-reject" data-session-reject="{{ claim.sessionId }}">{{ 'moderator.reject'|trans }}</button>
                                            </div>
                                        </div>
                                    </td>
                                {% endif %}
                                {% if showRevoke is defined and showRevoke %}
                                    <td>
                                        <button type="button" class="btn btn-reject" data-session-revoke="{{ claim.sessionId }}">{{ 'session_claim.revoke'|trans }}</button>
                                    </td>
                                {% endif %}
                            </tr>
