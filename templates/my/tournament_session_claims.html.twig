{% extends 'base.html.twig' %}

{% block title %}{{ 'session_claim.tournament_claims_title'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span>{{ 'session_claim.tournament_claims_title'|trans }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ 'session_claim.tournament_claims_title'|trans }}</h1>

    <h2>{{ 'session_claim.pending_section_title'|trans }}</h2>

    {% if grouped is empty %}
        <p class="empty-state">{{ 'session_claim.no_pending'|trans }}</p>
    {% else %}
        {% for group in grouped %}
            <div class="card card-wide" id="tournament-claims-{{ group.tournamentId }}">
                <h3><a href="{{ path('tournament_show', {id: group.tournamentId}) }}">{{ group.tournamentName }}</a></h3>

                <table aria-label="{{ group.tournamentName }}">
                    <thead>
                        <tr>
                            <th>{{ 'venue.venue'|trans }}</th>
                            <th>{{ 'common.town'|trans }}</th>
                            <th>{{ 'session_claim.estimated_date'|trans }}</th>
                            <th>{{ 'session_claim.estimated_teams'|trans }}</th>
                            <th>{{ 'venue.representative'|trans }}</th>
                            <th>{{ 'venue.host'|trans }}</th>
                            <th>{{ 'tournament.my.actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for claim in group.claims %}
                            {{ include('my/_session_claim_row.html.twig', {claim: claim, rowIndex: loop.index, sessionClaimId: claim.sessionId, showActions: true}, with_context: false) }}
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endfor %}
    {% endif %}

    <h2>{{ 'session_claim.approved_section_title'|trans }}</h2>

    <div id="approved-section">
        {% if active is empty %}
            <p class="empty-state">{{ 'session_claim.no_approved'|trans }}</p>
        {% else %}
            {% for group in active %}
                <div class="card card-wide" id="tournament-approved-{{ group.tournamentId }}">
                    <h3><a href="{{ path('tournament_show', {id: group.tournamentId}) }}">{{ group.tournamentName }}</a></h3>

                    <table aria-label="{{ group.tournamentName }}">
                        <thead>
                            <tr>
                                <th>{{ 'venue.venue'|trans }}</th>
                                <th>{{ 'common.town'|trans }}</th>
                                <th>{{ 'session_claim.estimated_date'|trans }}</th>
                                <th>{{ 'session_claim.estimated_teams'|trans }}</th>
                                <th>{{ 'venue.representative'|trans }}</th>
                                <th>{{ 'venue.host'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for claim in group.claims %}
                                {{ include('my/_session_claim_row.html.twig', {claim: claim, rowIndex: loop.index}, with_context: false) }}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endfor %}
        {% endif %}
    </div>
{% endblock %}
