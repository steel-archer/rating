{% extends 'base.html.twig' %}

{% block title %}{{ tournament.name }} — {{ 'tournament.my.edit'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span><a href="{{ path('my_tournaments') }}">{{ 'tournament.my.title'|trans }}</a></span><span>{{ tournament.name }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ tournament.name }}</h1>

    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message|trans }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message|trans }}</div>
    {% endfor %}

    {# --- Статус і дії --- #}
    <div class="cards-row">
        <div class="card status-card">
            <h2>{{ 'tournament.my.status'|trans }}</h2>
            <dl>
                <dt>{{ 'tournament.my.tournament_status'|trans }}</dt>
                <dd>{{ ('tournament.status.' ~ tournament.status)|trans }}</dd>
                <dt>{{ 'tournament.my.moderation'|trans }}</dt>
                <dd>
                    {% if claim %}
                        {{ ('tournament.moderation_status.' ~ claim.status)|trans }}
                        {% if claim.comment %}
                            <br><small>{{ claim.comment }}</small>
                        {% endif %}
                    {% else %}
                        {{ 'tournament.moderation_status.none'|trans }}
                    {% endif %}
                </dd>
                <dt>{{ 'tournament.sessions'|trans }}</dt>
                <dd><a href="{{ path('tournament_sessions', {id: tournament.id}) }}">{{ 'tournament.sessions'|trans }}</a></dd>
            </dl>
        </div>

        <div class="card">
            <h2>{{ 'tournament.my.actions'|trans }}</h2>
            <div class="actions-card">
                {% if (not claim or claim.status not in ['pending', 'approved']) and tournament.status != 'published' %}
                    <button type="button" class="btn btn-primary" data-tournament-submit="{{ tournament.id }}">{{ 'tournament.my.submit_moderation'|trans }}</button>
                {% endif %}

                {% if publishErrors is empty and tournament.status != 'published' %}
                    <button type="button" class="btn btn-success" data-tournament-publish="{{ tournament.id }}">{{ 'tournament.my.publish'|trans }}</button>
                {% endif %}

                {% if tournament.status != 'published' %}
                    <button type="button" class="btn btn-reject" data-tournament-delete="{{ tournament.id }}" data-confirm="{{ 'tournament.my.delete_confirm'|trans }}">{{ 'tournament.my.delete'|trans }}</button>
                {% endif %}
            </div>
        </div>
    </div>

    {# --- Основна інформація --- #}
    <div class="card">
        <h2>{{ 'tournament.my.general_info'|trans }}</h2>
        {% if readonly %}
            <p class="flash flash-info">{{ 'tournament.my.readonly_notice'|trans }}</p>
        {% endif %}
        <form id="tournament-edit-form" class="tournament-form" data-url="{{ path('my_tournament_update', {id: tournament.id}) }}">

            <div class="form-group">
                <label for="name">{{ 'common.name'|trans }} *</label>
                <input type="text" id="name" name="name" value="{{ tournament.name }}" required {{ readonly ? 'disabled' : '' }}>
            </div>
            <div class="form-group">
                <label for="started_at">{{ 'tournament.my.start_datetime'|trans }} <span class="required-publish">{{ 'tournament.my.required_for_publish'|trans }}</span></label>
                <input type="date" id="started_at" name="startedAt" value="{{ tournament.startedAt ? tournament.startedAt|date('Y-m-d') : '' }}" {{ readonly ? 'disabled' : '' }}>
                <small class="hint">{{ 'tournament.my.start_time_hint'|trans }}</small>
            </div>
            <div class="form-group">
                <label for="ended_at">{{ 'tournament.my.end_datetime'|trans }} <span class="required-publish">{{ 'tournament.my.required_for_publish'|trans }}</span></label>
                <input type="date" id="ended_at" name="endedAt" value="{{ tournament.endedAt ? tournament.endedAt|date('Y-m-d') : '' }}" {{ readonly ? 'disabled' : '' }}>
                <small class="hint">{{ 'tournament.my.end_time_hint'|trans }}</small>
            </div>
            <div class="form-group">
                <label for="results_hidden_until">{{ 'tournament.my.results_hidden_until'|trans }} <span class="required-publish">{{ 'tournament.my.required_for_publish'|trans }}</span></label>
                <input type="date" id="results_hidden_until" name="resultsHiddenUntil" value="{{ tournament.resultsHiddenUntil ? tournament.resultsHiddenUntil|date('Y-m-d') : '' }}" {{ readonly ? 'disabled' : '' }}>
                <small class="hint">{{ 'tournament.my.results_hidden_until_hint'|trans }}</small>
            </div>
            <div class="form-group">
                <label for="registration_deadline">{{ 'tournament.my.registration_deadline'|trans }} <span class="required-publish">{{ 'tournament.my.required_for_publish'|trans }}</span></label>
                <input type="date" id="registration_deadline" name="registrationDeadline" value="{{ tournament.registrationDeadline ? tournament.registrationDeadline|date('Y-m-d') : '' }}" {{ readonly ? 'disabled' : '' }}>
                <small class="hint">{{ 'tournament.my.registration_deadline_hint'|trans }}</small>
            </div>
            <div class="form-group">
                <label for="details_hidden_until">{{ 'tournament.my.details_hidden_until'|trans }} <span class="required-publish">{{ 'tournament.my.required_for_publish'|trans }}</span></label>
                <input type="date" id="details_hidden_until" name="detailsHiddenUntil" value="{{ tournament.detailsHiddenUntil ? tournament.detailsHiddenUntil|date('Y-m-d') : '' }}" {{ readonly ? 'disabled' : '' }}>
                <small class="hint">{{ 'tournament.my.details_hidden_until_hint'|trans }}</small>
            </div>
            <div class="form-group">
                <label for="submission_deadline">{{ 'tournament.my.submission_deadline'|trans }} <span class="required-publish">{{ 'tournament.my.required_for_publish'|trans }}</span></label>
                <input type="date" id="submission_deadline" name="submissionDeadline" value="{{ tournament.submissionDeadline ? tournament.submissionDeadline|date('Y-m-d') : '' }}" {{ readonly ? 'disabled' : '' }}>
                <small class="hint">{{ 'tournament.my.submission_deadline_hint'|trans }}</small>
            </div>
            <div class="form-group">
                <label for="appeal_deadline">{{ 'tournament.my.appeal_deadline'|trans }} <span class="required-publish">{{ 'tournament.my.required_for_publish'|trans }}</span></label>
                <input type="date" id="appeal_deadline" name="appealDeadline" value="{{ tournament.appealDeadline ? tournament.appealDeadline|date('Y-m-d') : '' }}" {{ readonly ? 'disabled' : '' }}>
                <small class="hint">{{ 'tournament.my.appeal_deadline_hint'|trans }}</small>
            </div>
            <div class="form-group">
                <label for="tours_count">{{ 'tournament.tours_count'|trans }} <span class="required-publish">{{ 'tournament.my.required_for_publish'|trans }}</span></label>
                <input type="number" id="tours_count" name="toursCount" min="1" step="1" value="{{ tournament.toursCount }}" {{ readonly ? 'disabled' : '' }}>
            </div>
            <div class="form-group">
                <label for="questions_per_tour">{{ 'tournament.questions_per_tour'|trans }} <span class="required-publish">{{ 'tournament.my.required_for_publish'|trans }}</span></label>
                <input type="number" id="questions_per_tour" name="questionsPerTour" min="1" step="1" value="{{ tournament.questionsPerTour }}" {{ readonly ? 'disabled' : '' }}>
            </div>
            <div class="form-group">
                <label for="difficulty">{{ 'tournament.difficulty'|trans }} <span class="required-publish">{{ 'tournament.my.required_for_publish'|trans }}</span></label>
                <input type="number" id="difficulty" name="difficulty" min="1" max="10" step="0.5" value="{{ tournament.difficulty }}" {{ readonly ? 'disabled' : '' }}>
            </div>
            <div class="form-group">
                <label for="discussion_link">{{ 'tournament.discussion_link'|trans }}</label>
                <input type="text" id="discussion_link" name="discussionLink" maxlength="512" value="{{ tournament.discussionLink }}" placeholder="https://" {{ readonly ? 'disabled' : '' }}>
                <small class="hint">{{ 'tournament.my.discussion_link_hint'|trans }}</small>
            </div>

            {# --- Офіційні особи --- #}
            <h2>{{ 'tournament.officials'|trans }}</h2>

            {% set roleConfig = [
                {key: 'organizers', role: 'organizer', label: 'tournament.role.organizer'},
                {key: 'editors', role: 'editor', label: 'tournament.role.editor'},
                {key: 'gameJury', role: 'game_jury', label: 'tournament.role.game_jury'},
                {key: 'appealJury', role: 'appeal_jury', label: 'tournament.role.appeal_jury'},
            ] %}

            {% for cfg in roleConfig %}
                <div class="form-group">
                    <label>{{ cfg.label|trans }} <span class="required-publish">{{ 'tournament.my.required_for_publish'|trans }}</span></label>
                    <div class="officials-group" data-role="{{ cfg.key }}">
                        {% set roleOfficials = officials|filter(o => o.role == cfg.role) %}
                        {% for official in roleOfficials %}
                            <div class="official-entry">
                                <input type="hidden" name="{{ cfg.key }}[]" value="{{ official.playerId }}">
                                {{ include('_player_link.html.twig', {playerId: official.playerId, playerName: official.playerName, hasUser: official.hasUser}, with_context: false) }}
                                {% if not readonly and not (cfg.role == 'organizer' and official.playerId == tournament.createdByPlayerId) %}
                                    <button type="button" class="btn-remove">×</button>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                    {% if not readonly %}
                        <div class="suggest-wrapper" data-suggest-url="{{ path('api_players_suggest') }}">
                            <input type="text" data-suggest-input placeholder="{{ 'tournament.my.add_official'|trans }}">
                            <div data-suggest-dropdown hidden></div>
                        </div>
                    {% endif %}
                </div>
            {% endfor %}

            {% if not readonly %}
                <button type="submit" class="btn">{{ 'tournament.my.save'|trans }}</button>
                <span id="save-status" class="save-status" hidden></span>
            {% endif %}
        </form>
    </div>

    {# --- Документи --- #}
    <div class="card">
        <h2>{{ 'tournament.document.title'|trans }}</h2>
        <p class="hint">{{ 'tournament.document.hint'|trans }}</p>

        <div id="documents-list" data-tournament-id="{{ tournament.id }}">
            {% for doc in documents %}
                <div class="document-entry" data-document-id="{{ doc.id }}">
                    <a href="{{ path('my_tournament_document_download', {id: doc.id}) }}" class="document-link">{{ doc.originalName }}</a>
                    <span class="document-size">({{ (doc.size / 1024)|round(0) }} KB)</span>
                    {% if not readonly %}
                        <button type="button" class="btn-remove" data-document-delete="{{ doc.id }}">×</button>
                    {% endif %}
                </div>
            {% endfor %}
        </div>

        {% if not readonly %}
            <div class="form-group" id="document-upload-group" {% if documents|length >= 3 %}hidden{% endif %}>
                <input type="file" id="document-file" accept=".pdf,.doc,.docx,.odt">
                <button type="button" class="btn" id="document-upload-btn">{{ 'tournament.document.upload'|trans }}</button>
                <span id="document-upload-status" class="save-status" hidden></span>
            </div>
        {% endif %}
    </div>

    {# --- Вимоги для публікації --- #}
    {% if not readonly and publishErrors is not empty %}
        <div class="card publish-errors">
            <h2>{{ 'tournament.my.publish_requirements'|trans }}</h2>
            <ul>
                {% for error in publishErrors %}
                    <li>{{ error|trans }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}
{% endblock %}
