{% extends 'base.html.twig' %}

{% block title %}{{ 'tournament.my.create'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span><a href="{{ path('my_tournaments') }}">{{ 'tournament.my.title'|trans }}</a></span><span>{{ 'tournament.my.create'|trans }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ 'tournament.my.create'|trans }}</h1>

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message|trans }}</div>
    {% endfor %}

    <div class="card">
        <form id="tournament-create-form" class="tournament-form" data-url="{{ path('my_tournament_store') }}">
            <div class="form-group">
                <label for="name">{{ 'common.name'|trans }} *</label>
                <input type="text" id="name" name="name" required>
            </div>
            <div class="form-group">
                <label>{{ 'tournament.format.label'|trans }} *</label>
                <div class="format-options">
                    <label class="format-option">
                        <input type="radio" name="format" value="distributed" checked>
                        <span class="format-option-label">
                            {{ 'tournament.format.distributed'|trans }}
                            <span class="format-hint-icon" data-tooltip="{{ 'tournament.format.distributed_hint'|trans }}">?</span>
                        </span>
                    </label>
                    <label class="format-option">
                        <input type="radio" name="format" value="centralized">
                        <span class="format-option-label">
                            {{ 'tournament.format.centralized'|trans }}
                            <span class="format-hint-icon" data-tooltip="{{ 'tournament.format.centralized_hint'|trans }}">?</span>
                        </span>
                    </label>
                </div>
            </div>
            <div class="form-group">
                <label>{{ 'tournament.online_mode.label'|trans }} *</label>
                <div class="format-options">
                    <label class="format-option">
                        <input type="radio" name="onlineMode" value="mixed" checked>
                        <span class="format-option-label">
                            {{ 'tournament.online_mode.mixed'|trans }}
                            <span class="format-hint-icon" data-tooltip="{{ 'tournament.online_mode.mixed_hint'|trans }}">?</span>
                        </span>
                    </label>
                    <label class="format-option">
                        <input type="radio" name="onlineMode" value="offline">
                        <span class="format-option-label">
                            {{ 'tournament.online_mode.offline'|trans }}
                            <span class="format-hint-icon" data-tooltip="{{ 'tournament.online_mode.offline_hint'|trans }}">?</span>
                        </span>
                    </label>
                    <label class="format-option">
                        <input type="radio" name="onlineMode" value="online">
                        <span class="format-option-label">
                            {{ 'tournament.online_mode.online'|trans }}
                            <span class="format-hint-icon" data-tooltip="{{ 'tournament.online_mode.online_hint'|trans }}">?</span>
                        </span>
                    </label>
                </div>
            </div>
            <button type="submit" class="btn">{{ 'tournament.my.create'|trans }}</button>
            <span id="save-status" class="save-status" hidden></span>
        </form>
    </div>
{% endblock %}
