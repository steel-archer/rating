{% extends 'base.html.twig' %}

{% block title %}{{ player.fullName }} — {{ 'nav.players'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span><a href="{{ path('player_index') }}">{{ 'nav.players'|trans }}</a></span><span>{{ player.fullName }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ player.fullName }}</h1>

    {% if player.townName or playerEmail %}
        <div class="meta">
            {% if player.townName %}<span>{{ player.townName }}</span>{% endif %}
            {% if playerEmail %}<span>{{ 'common.email'|trans }}: {{ playerEmail }}</span>{% endif %}
        </div>
    {% endif %}

    {% if player.squads is not empty %}
        <div class="card">
            <h2>{{ 'team.base_squads'|trans }}</h2>
            <dl>
                {% for squad in player.squads %}
                    <dt>{{ squad.seasonName }}</dt>
                    <dd><a href="{{ path('team_show', {id: squad.teamId}) }}">{{ squad.teamName }}</a>{% if squad.isCaptain %} (к){% endif %}</dd>
                {% endfor %}
            </dl>
        </div>
    {% endif %}

    {% if player.tournamentCount > 0 %}
        <turbo-frame id="player-tournaments" src="{{ path('player_tournaments', {id: player.id}) }}">
            <p>{{ 'common.loading_tournaments'|trans }}</p>
        </turbo-frame>
    {% endif %}
{% endblock %}
