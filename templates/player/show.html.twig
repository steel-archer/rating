{% extends 'base.html.twig' %}

{% block title %}{{ player.fullName }} — Гравці — Rating{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">Головна</a><span><a href="{{ path('player_index') }}">Гравці</a></span><span>{{ player.fullName }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ player.fullName }}</h1>
    {% if player.townName %}
        <div class="meta"><span>{{ player.townName }}</span></div>
    {% endif %}

    {% if player.squads is not empty %}
        <div class="card">
            <h2>Базові склади</h2>
            <dl>
                {% for squad in player.squads %}
                    <dt>{{ squad.seasonName }}</dt>
                    <dd><a href="{{ path('team_show', {id: squad.teamId}) }}">{{ squad.teamName }}</a>{% if squad.isCaptain %} (к){% endif %}</dd>
                {% endfor %}
            </dl>
        </div>
    {% endif %}

    {% if player.tournamentCount > 0 %}
        <turbo-frame id="player-tournaments" src="{{ path('player_tournaments', {id: player.id}) }}">
            <p>Завантаження турнірів…</p>
        </turbo-frame>
    {% endif %}
{% endblock %}
