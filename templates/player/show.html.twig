{% extends 'base.html.twig' %}

{% block title %}{{ player.fullName }} — {{ 'nav.players'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span><a href="{{ path('player_index') }}">{{ 'nav.players'|trans }}</a></span><span>{{ player.fullName }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ player.fullName }}</h1>

    {% if player.townName %}
        <div class="meta">
            <span>{{ player.townName }}</span>
        </div>
    {% endif %}

    {% if userIsBlocked %}
        <div class="flash-error">🚫 {{ 'block.player_blocked_notice'|trans }}</div>
    {% endif %}

    {% if contacts %}
        <div class="card" id="player-contacts">
            <h2>{{ 'contact.title'|trans }}</h2>
            <div id="contacts-flash" hidden></div>

            {% if canEditContacts %}
                <form id="contacts-form" data-url="{{ path('my_contacts_update') }}">
                    <div class="contacts-row">
                        <div class="form-group">
                            <label for="contact-email">✉️ {{ 'common.email'|trans }}</label>
                            <span class="contact-value" id="contact-email">{{ contacts.email }}</span>
                        </div>
                        <div class="form-group">
                            <label for="contact-telegram">💬 {{ 'contact.telegram'|trans }} <span class="hint-inline">({{ 'contact.optional'|trans }})</span></label>
                            <input type="text" id="contact-telegram" name="telegram" value="{{ contacts.telegram }}" placeholder="{{ 'contact.telegram.placeholder'|trans }}" class="search-input" maxlength="32">
                        </div>
                        <div class="form-group">
                            <label for="contact-facebook">👤 {{ 'contact.facebook'|trans }} <span class="hint-inline">({{ 'contact.optional'|trans }})</span></label>
                            <input type="text" id="contact-facebook" name="facebook" value="{{ contacts.facebook }}" placeholder="{{ 'contact.facebook.placeholder'|trans }}" class="search-input" maxlength="50">
                        </div>
                        <div class="form-group">
                            <label for="contact-phone">📞 {{ 'contact.phone'|trans }} <span class="hint-inline">({{ 'contact.optional'|trans }})</span></label>
                            <input type="tel" id="contact-phone" name="phone" value="{{ contacts.phone }}" placeholder="{{ 'contact.phone.placeholder'|trans }}" class="search-input" maxlength="20">
                        </div>
                    </div>
                    <button type="submit" class="search-btn">{{ 'contact.save'|trans }}</button>
                </form>
                <p class="contacts-info">🔒 {{ 'contact.visibility_warning'|trans }}</p>
            {% else %}
                <dl>
                    <dt>✉️ {{ 'common.email'|trans }}</dt>
                    <dd>{{ contacts.email }}</dd>
                    {% if contacts.telegram %}
                        <dt>💬 {{ 'contact.telegram'|trans }}</dt>
                        <dd><a href="https://t.me/{{ contacts.telegram }}" target="_blank" rel="noopener">@{{ contacts.telegram }}</a></dd>
                    {% endif %}
                    {% if contacts.facebook %}
                        <dt>👤 {{ 'contact.facebook'|trans }}</dt>
                        <dd><a href="https://facebook.com/{{ contacts.facebook }}" target="_blank" rel="noopener">{{ contacts.facebook }}</a></dd>
                    {% endif %}
                    {% if contacts.phone %}
                        <dt>📞 {{ 'contact.phone'|trans }}</dt>
                        <dd>{{ contacts.phone }}</dd>
                    {% endif %}
                </dl>
            {% endif %}
        </div>
    {% endif %}

    {% if player.squads is not empty %}
        <div class="card">
            <h2>{{ 'team.base_squads'|trans }}</h2>
            <dl>
                {% for squad in player.squads %}
                    <dt>{{ squad.seasonName }}</dt>
                    <dd><a href="{{ path('team_show', {id: squad.teamId}) }}">{{ squad.teamName }}</a>{% if squad.isCaptain %} (к){% endif %}</dd>
                {% endfor %}
            </dl>
        </div>
    {% endif %}

    {% if player.tournamentCount > 0 %}
        <turbo-frame id="player-tournaments" src="{{ path('player_tournaments', {id: player.id}) }}">
            <p>{{ 'common.loading_tournaments'|trans }}</p>
        </turbo-frame>
    {% endif %}

    {% if userId and is_granted('ROLE_MODERATOR') and not canEditContacts %}
        <div class="card">
            <a href="{{ path('moderator_user_block', {id: userId}) }}" class="btn btn-reject">{{ userIsBlocked ? 'block.blocked_status'|trans : 'block.block'|trans }}</a>
        </div>
    {% endif %}
{% endblock %}
