<turbo-frame id="player-tournaments">
    <div class="card card-wide">
        <h2>{{ 'nav.tournaments'|trans }}</h2>
        <table aria-label="{{ 'nav.tournaments'|trans }}">
            <thead>
                <tr>
                    <th>{{ 'common.tournament'|trans }}</th>
                    <th>{{ 'common.date'|trans }}</th>
                    <th></th>
                    <th>{{ 'common.team'|trans }}</th>
                    <th>{{ 'common.town'|trans }}</th>
                    <th>{{ 'common.place'|trans }}</th>
                    <th>{{ 'common.result'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for appearance in tournaments %}
                    <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}">
                        <td><a href="{{ path('tournament_show', {id: appearance.tournamentId}) }}" data-turbo-frame="_top" data-turbo="false">{{ appearance.tournamentName }}</a></td>
                        <td>{{ appearance.playedAt ? appearance.playedAt|date('d.m.Y') : '—' }}</td>
                        <td class="one-time-name-hint">{% if appearance.oneTimeName %}<span data-tooltip="{{ 'team.base_name'|trans({'%name%': appearance.teamName ~ ' (' ~ appearance.teamTownName ~ ')'}) }}">^</span>{% endif %}</td>
                        <td>{{ include('_team_name.html.twig', {teamId: appearance.teamId, teamName: appearance.teamName, oneTimeName: appearance.oneTimeName, turboFrame: true}, with_context: false) }}{% if appearance.isLegionary %} <em>(не в складі)</em>{% endif %}</td>
                        <td>{{ appearance.teamTownName }}</td>
                        <td>{{ appearance.place ? (appearance.place == appearance.place|round(0) ? appearance.place|number_format(0) : appearance.place) : '—' }}</td>
                        <td>{{ appearance.score ?? '—' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {{ include('_pagination.html.twig', {paginationRoute: 'player_tournaments', paginationParams: {id: playerId}}) }}
    </div>
</turbo-frame>
