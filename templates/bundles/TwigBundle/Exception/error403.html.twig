{% extends 'base.html.twig' %}

{% block title %}{{ 'error.403.title'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block body %}
    <div class="error-page">
        <div class="error-code">403</div>
        <div class="error-message">{{ 'error.403.title'|trans }}</div>
        <p class="error-hint">{{ 'error.403.hint'|trans }}</p>
        <a href="/" class="error-link">{{ 'error.back_home'|trans }}</a>
    </div>
{% endblock %}
