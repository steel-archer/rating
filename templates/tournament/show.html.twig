{% extends 'base.html.twig' %}

{% block title %}{{ tournament.name }} — {{ 'nav.tournaments'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span><a href="{{ path('tournament_index') }}">{{ 'nav.tournaments'|trans }}</a></span><span>{{ tournament.name }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ tournament.name }}</h1>
    <div class="meta">
        {% if tournament.startedAt %}<span>{{ tournament.startedAt|date('d.m.Y') }}{% if tournament.endedAt %} — {{ tournament.endedAt|date('d.m.Y') }}{% endif %}</span>{% endif %}
    </div>

    <div class="cards-row">
        <div class="card">
            <dl>
                {% if tournament.toursCount %}
                    <dt>{{ 'tournament.tours_count'|trans }}</dt>
                    <dd>{{ tournament.toursCount }}</dd>
                {% endif %}
                {% if tournament.questionsPerTour %}
                    <dt>{{ 'tournament.questions_per_tour'|trans }}</dt>
                    <dd>{{ tournament.questionsPerTour }}</dd>
                {% endif %}
                {% if tournament.teamCount %}
                    <dt>{{ 'common.teams_count'|trans }}</dt>
                    <dd>{{ tournament.teamCount }}</dd>
                {% endif %}
                {% if tournament.difficulty %}
                    <dt>{{ 'tournament.difficulty'|trans }}</dt>
                    <dd>{{ tournament.difficulty }}</dd>
                {% endif %}
                {% if tournament.trueDl %}
                    <dt>{{ 'tournament.true_dl'|trans }}</dt>
                    <dd>{{ tournament.trueDl }}</dd>
                {% endif %}
                {% if tournament.registrationDeadline %}
                    <dt>{{ 'tournament.registration_deadline'|trans }}</dt>
                    <dd>{{ tournament.registrationDeadline|date('d.m.Y H:i') }}</dd>
                {% endif %}
                {% if tournament.resultsHiddenUntil %}
                    <dt>{{ 'tournament.results_hidden_until'|trans }}</dt>
                    <dd>{{ tournament.resultsHiddenUntil|date('d.m.Y H:i') }}</dd>
                {% endif %}
                {% if tournament.detailsHiddenUntil %}
                    <dt>{{ 'tournament.details_hidden_until'|trans }}</dt>
                    <dd>{{ tournament.detailsHiddenUntil|date('d.m.Y H:i') }}</dd>
                {% endif %}
                {% if tournament.submissionDeadline %}
                    <dt>{{ 'tournament.submission_deadline'|trans }}</dt>
                    <dd>{{ tournament.submissionDeadline|date('d.m.Y H:i') }}</dd>
                {% endif %}
                {% if tournament.sessionCount %}
                    <dt>{{ 'tournament.sessions'|trans }}</dt>
                    <dd><a href="{{ path('tournament_sessions', {id: tournament.id}) }}">{{ tournament.sessionCount }}</a></dd>
                {% else %}
                    <dt>{{ 'tournament.sessions'|trans }}</dt>
                    <dd><a href="{{ path('tournament_sessions', {id: tournament.id}) }}">0</a></dd>
                {% endif %}
                {% if canViewDisputes %}
                    <dt>{{ 'dispute.title'|trans }}</dt>
                    <dd><a href="{{ path('tournament_disputes', {id: tournament.id}) }}">{{ tournament.disputeCount }}</a></dd>
                {% endif %}
            </dl>
        </div>

        {% if tournament.officials is not empty %}
            <div class="card card-grow">
                <h2>{{ 'tournament.officials'|trans }}</h2>
                <dl>
                    {% set roleOrder = ['organizer', 'editor', 'game_jury', 'appeal_jury'] %}
                    {% for role in roleOrder %}
                        {% if tournament.officials[role] is defined %}
                            <dt>{{ ('tournament.role.' ~ role)|trans }}</dt>
                            <dd>
                                {% for p in tournament.officials[role] %}
                                    {% if not loop.first %}, {% endif %}
                                    {{ include('_player_link.html.twig', {playerId: p.playerId, playerName: p.playerName, hasUser: p.hasUser}, with_context: false) }}
                                {% endfor %}
                            </dd>
                        {% endif %}
                    {% endfor %}
                </dl>
            </div>
        {% endif %}
    </div>

    {% if moderationClaim and moderationClaim.status == 'pending' %}
        <div class="card moderation-card">
            <h2>{{ 'nav.moderation'|trans }}</h2>
            <div class="moderation-actions">
                <button type="button" class="btn btn-approve" data-tournament-approve="{{ tournament.id }}">{{ 'moderator.approve'|trans }}</button>
                <div class="reject-form">
                    <input type="text" class="reject-input" placeholder="{{ 'moderator.reject_comment'|trans }}" data-tournament-reject-comment="{{ tournament.id }}">
                    <button type="button" class="btn btn-reject" data-tournament-reject="{{ tournament.id }}">{{ 'moderator.reject'|trans }}</button>
                </div>
            </div>
        </div>
    {% endif %}

    {% if tournament.teamCount > 0 %}
        <turbo-frame id="tournament-results" src="{{ path('tournament_results', {id: tournament.id}) }}">
            <p>{{ 'common.loading_results'|trans }}</p>
        </turbo-frame>
    {% endif %}
{% endblock %}
