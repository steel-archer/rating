{% extends 'base.html.twig' %}

{% block title %}{{ tournament.name }} — Турніри — Rating{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">Головна</a><span><a href="{{ path('tournament_index') }}">Турніри</a></span><span>{{ tournament.name }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ tournament.name }}</h1>
    <div class="meta">
        {% if tournament.startedAt %}<span>{{ tournament.startedAt|date('d.m.Y') }}{% if tournament.endedAt %} — {{ tournament.endedAt|date('d.m.Y') }}{% endif %}</span>{% endif %}
    </div>

    <div class="cards-row">
        <div class="card">
            <dl>
                {% if tournament.toursCount %}
                    <dt>Турів</dt>
                    <dd>{{ tournament.toursCount }}</dd>
                {% endif %}
                {% if tournament.questionsPerTour %}
                    <dt>Питань у турі</dt>
                    <dd>{{ tournament.questionsPerTour }}</dd>
                {% endif %}
                {% if tournament.teamCount %}
                    <dt>Команд</dt>
                    <dd>{{ tournament.teamCount }}</dd>
                {% endif %}
                {% if tournament.difficulty %}
                    <dt>Складність</dt>
                    <dd>{{ tournament.difficulty }}</dd>
                {% endif %}
                {% if tournament.trueDl %}
                    <dt>True DL</dt>
                    <dd>{{ tournament.trueDl }}</dd>
                {% endif %}
                {% if tournament.sessionCount %}
                    <dt>Відіграші</dt>
                    <dd><a href="{{ path('tournament_sessions', {id: tournament.id}) }}">{{ tournament.sessionCount }}</a></dd>
                {% endif %}
            </dl>
        </div>

        {% if tournament.officials is not empty %}
            <div class="card card-grow">
                <h2>Офіційні особи</h2>
                <dl>
                    {% set roleOrder = ['organizer', 'editor', 'game_jury', 'appeal_jury'] %}
                    {% for role in roleOrder %}
                        {% if tournament.officials[role] is defined %}
                            <dt>{{ role == 'organizer' ? 'Організатори' : (role == 'editor' ? 'Редактори' : (role == 'game_jury' ? 'Ігрове журі' : 'Апеляційне журі')) }}</dt>
                            <dd>{{ tournament.officials[role]|map(p => '<a href="' ~ path('player_show', {id: p.playerId}) ~ '">' ~ p.playerName|e ~ '</a>')|join(', ')|raw }}</dd>
                        {% endif %}
                    {% endfor %}
                </dl>
            </div>
        {% endif %}
    </div>

    {% if tournament.teamCount > 0 %}
        <turbo-frame id="tournament-results" src="{{ path('tournament_results', {id: tournament.id}) }}">
            <p>Завантаження результатів…</p>
        </turbo-frame>
    {% endif %}
{% endblock %}
