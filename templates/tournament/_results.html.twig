<turbo-frame id="tournament-results">
    <div class="card card-wide">
        <h2>Результати</h2>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Команда</th>
                    <th>Місто</th>
                    <th>Результат</th>
                    <th>
                        Склад
                        <button type="button" class="btn-toggle-text" data-toggle-all-squads>показати всі</button>
                    </th>
                </tr>
            </thead>
            <tbody>
                {% for team in teams %}
                    <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}{{ team.baseSquadCount < 3 ? ' squad-weak' : '' }}">
                        <td>{{ team.place ? (team.place == team.place|round(0) ? team.place|number_format(0) : team.place) : '—' }}</td>
                        <td><a href="{{ path('team_show', {id: team.teamId}) }}" data-turbo-frame="_top">{{ team.teamName }}</a></td>
                        <td>{{ team.teamTownName }}</td>
                        <td>{{ team.score ?? '—' }}</td>
                        <td>
                            <button type="button" class="btn-toggle-text" data-toggle-squad>показати</button>
                            <div class="squad-list" hidden>
                                {% for player in team.players %}
                                    <div class="{{ player.isBaseSquad ? 'player-base' : 'player-guest' }}">
                                        <a href="{{ path('player_show', {id: player.playerId}) }}" data-turbo-frame="_top">{{- player.playerName -}}</a>
                                        {%- if player.isCaptain %} (к){% endif -%}
                                    </div>
                                {% endfor %}
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {% include '_pagination.html.twig' with {paginationRoute: 'tournament_results', paginationParams: {id: tournament.id}} %}
    </div>
</turbo-frame>
