{% extends 'base.html.twig' %}

{% block title %}Відіграші — {{ tournament.name }} — Турніри — Rating{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">Головна</a><span><a href="{{ path('tournament_index') }}">Турніри</a></span><span><a href="{{ path('tournament_show', {id: tournament.id}) }}">{{ tournament.name }}</a></span><span>Відіграші</span></nav>
{% endblock %}

{% block body %}
    <h1>Відіграші: {{ tournament.name }}</h1>

    <turbo-frame id="tournament-sessions" src="{{ path('tournament_sessions_list', {id: tournament.id}) }}">
        <p>Завантаження…</p>
    </turbo-frame>
{% endblock %}
