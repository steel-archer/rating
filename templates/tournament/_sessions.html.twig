<turbo-frame id="tournament-sessions">
    <div class="card card-wide">
        {% if sessions is empty %}
            <p class="empty-state">{{ 'tournament.no_sessions'|trans }}</p>
        {% else %}
            <table aria-label="{{ 'tournament.sessions'|trans }}">
                <thead>
                    <tr>
                        <th>{{ 'venue.venue'|trans }}</th>
                        <th>{{ 'common.town'|trans }}</th>
                        <th>{{ 'common.date'|trans }}</th>
                        <th>{{ 'venue.representative'|trans }}</th>
                        <th>{{ 'venue.host'|trans }}</th>
                        <th>{{ 'session_claim.estimated_teams'|trans }}</th>
                        <th>{{ 'common.teams_count'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for s in sessions %}
                        <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}">
                            <td><a href="{{ path('venue_show', {id: s.venueId}) }}" data-turbo-frame="_top" data-turbo="false">{{ s.venueName }}</a></td>
                            <td>{{ s.townName }}</td>
                            <td>{{ s.playedAt ? s.playedAt|date('d.m.Y') : '—' }}</td>
                            <td>{% include '_player_link.html.twig' with {playerId: s.representativeId, playerName: s.representativeName, hasUser: s.representativeHasUser, turboFrame: true} only %}</td>
                            <td>
                                {% if s.hostId %}
                                    {% include '_player_link.html.twig' with {playerId: s.hostId, playerName: s.hostName, hasUser: s.hostHasUser, turboFrame: true} only %}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>{{ s.estimatedTeams ?? '—' }}</td>
                            <td>{{ teamCounts[s.id] ?? 0 }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>

            {% include '_pagination.html.twig' with {paginationRoute: 'tournament_sessions_list', paginationParams: {id: tournament.id}} %}
        {% endif %}
    </div>
</turbo-frame>
