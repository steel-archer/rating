{% extends 'base.html.twig' %}

{% block title %}{{ 'nav.tournaments'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span>{{ 'nav.tournaments'|trans }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ 'nav.tournaments'|trans }}</h1>

    <turbo-frame id="tournaments-list" data-sync-url src="{{ path('tournament_list') }}{{ app.request.queryString ? '?' ~ app.request.queryString : '' }}">
        <p>{{ 'common.loading'|trans }}</p>
    </turbo-frame>
{% endblock %}
