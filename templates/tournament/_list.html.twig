<turbo-frame id="tournaments-list" data-sync-url>
    <div class="card search-form">
        <form action="{{ path('tournament_list') }}" method="get">
            <div class="search-row">
                <input type="text" name="name" value="{{ filters.name ?? '' }}" placeholder="{{ 'common.name'|trans }}" class="search-input">
                <button type="submit" class="search-btn">{{ 'common.search'|trans }}</button>
            </div>
        </form>
    </div>

    <div class="card card-wide">
        <table aria-label="{{ 'nav.tournaments'|trans }}">
            <thead>
                <tr>
                    <th>{{ 'common.name'|trans }}</th>
                    <th>{{ 'common.dates'|trans }}</th>
                    <th>{{ 'tournament.difficulty'|trans }}</th>
                    <th>{{ 'tournament.true_dl'|trans }}</th>
                    <th>{{ 'common.teams_count'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for t in tournaments %}
                    <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}">
                        <td><a href="{{ path('tournament_show', {id: t.id}) }}" data-turbo-frame="_top" data-turbo="false">{{ t.name }}</a></td>
                        <td>{{ t.startedAt ? t.startedAt|date('d.m.Y') : '—' }}{% if t.endedAt %} — {{ t.endedAt|date('d.m.Y') }}{% endif %}</td>
                        <td>{{ t.difficulty ?? '—' }}</td>
                        <td>{{ t.trueDl ?? '—' }}</td>
                        <td>{{ t.teamCount }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="5">{{ 'common.not_found'|trans }}</td></tr>
                {% endfor %}
            </tbody>
        </table>

        {% include '_pagination.html.twig' with {paginationRoute: 'tournament_list', paginationParams: filters} %}
    </div>
</turbo-frame>
