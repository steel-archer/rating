<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ 'site.title'|trans }}{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏆</text></svg>">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
    <header>
        <div class="header-inner">
            <a href="{{ path('home') }}" class="logo">Rating</a>
            <nav>
                <a href="{{ path('tournament_index') }}">{{ 'nav.tournaments'|trans }}</a>
                <a href="{{ path('team_index') }}">{{ 'nav.teams'|trans }}</a>
                <a href="{{ path('player_index') }}">{{ 'nav.players'|trans }}</a>
                <a href="{{ path('venue_index') }}">{{ 'nav.venues'|trans }}</a>
            </nav>
            <div class="auth">
                {% if app.user %}
                    {% if is_granted('ROLE_MODERATOR') %}
                        <div class="dropdown">
                            <span class="dropdown-toggle">{{ 'nav.moderation'|trans }}</span>
                            <div class="dropdown-menu">
                                <div class="dropdown-menu-inner">
                                    <a href="{{ path('moderator_claims') }}">{{ 'moderator.claims'|trans }}</a>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                    {% if app.user.player %}
                        <a href="{{ path('player_show', {id: app.user.player.id}) }}">{{ app.user.player.firstName }} {{ app.user.player.lastName }}</a>
                    {% else %}
                        <span>{{ app.user.email }}</span>
                    {% endif %}
                    <a href="{{ path('auth_logout') }}">{{ 'auth.logout'|trans }}</a>
                {% else %}
                    <a href="{{ path('auth_google_start') }}">{{ 'auth.login'|trans }}</a>
                {% endif %}
            </div>
        </div>
    </header>
    <main>
        <div class="container">
            {% block breadcrumbs %}{% endblock %}
            {% block body %}{% endblock %}
        </div>
    </main>
</body>
</html>
