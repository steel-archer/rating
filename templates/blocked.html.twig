{% extends 'base.html.twig' %}

{% block title %}{{ 'block.page_title'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block body %}
    <div class="error-page">
        <div class="error-code">🚫</div>
        <div class="error-message">{{ 'block.page_title'|trans }}</div>
        <p class="error-hint">{{ reason }}</p>
        <a href="{{ path('auth_logout') }}" class="error-link">{{ 'auth.logout'|trans }}</a>
    </div>
{% endblock %}
