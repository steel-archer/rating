<turbo-frame id="team-tournaments">
    <div class="card card-wide">
        <h2>{{ 'nav.tournaments'|trans }}</h2>
        <table aria-label="{{ 'nav.tournaments'|trans }}">
            <thead>
                <tr>
                    <th>{{ 'common.tournament'|trans }}</th>
                    <th>{{ 'common.date'|trans }}</th>
                    <th>{{ 'common.squad'|trans }}</th>
                    <th>{{ 'common.place'|trans }}</th>
                    <th>{{ 'common.result'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in tournaments %}
                    <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}{{ entry.baseSquadCount < 3 ? ' squad-weak' : '' }}">
                        <td><a href="{{ path('tournament_show', {id: entry.tournamentId}) }}" data-turbo-frame="_top" data-turbo="false">{{ entry.tournamentName }}</a></td>
                        <td>{{ entry.playedAt ? entry.playedAt|date('d.m.Y') : '—' }}</td>
                        <td>
                            {% for player in entry.players %}
                                <div class="{{ player.isBaseSquad ? 'player-base' : 'player-guest' }}">
                                    {{ include('_player_link.html.twig', {playerId: player.playerId, playerName: player.playerName, hasUser: player.hasUser, turboFrame: true}, with_context: false) }}
                                    {%- if player.isCaptain %} (к){% endif -%}
                                </div>
                            {% endfor %}
                        </td>
                        <td>{{ entry.place ? (entry.place == entry.place|round(0) ? entry.place|number_format(0) : entry.place) : '—' }}</td>
                        <td>{{ entry.score ?? '—' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {{ include('_pagination.html.twig', {paginationRoute: 'team_tournaments', paginationParams: {id: teamId}}) }}
    </div>
</turbo-frame>
