<turbo-frame id="team-tournaments">
    <div class="card card-wide">
        <h2>Турніри</h2>
        <table>
            <thead>
                <tr>
                    <th>Турнір</th>
                    <th>Дата</th>
                    <th>Склад</th>
                    <th>Місце</th>
                    <th>Результат</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in tournaments %}
                    <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}{{ entry.baseSquadCount < 3 ? ' squad-weak' : '' }}">
                        <td><a href="{{ path('tournament_show', {id: entry.tournamentId}) }}" data-turbo-frame="_top">{{ entry.tournamentName }}</a></td>
                        <td>{{ entry.playedAt ? entry.playedAt|date('d.m.Y') : '—' }}</td>
                        <td>
                            {% for player in entry.players %}
                                <div class="{{ player.isBaseSquad ? 'player-base' : 'player-guest' }}">
                                    <a href="{{ path('player_show', {id: player.playerId}) }}" data-turbo-frame="_top">{{- player.playerName -}}</a>
                                    {%- if player.isCaptain %} (к){% endif -%}
                                </div>
                            {% endfor %}
                        </td>
                        <td>{{ entry.place ? (entry.place == entry.place|round(0) ? entry.place|number_format(0) : entry.place) : '—' }}</td>
                        <td>{{ entry.score ?? '—' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {% include '_pagination.html.twig' with {paginationRoute: 'team_tournaments', paginationParams: {id: team.id}} %}
    </div>
</turbo-frame>
