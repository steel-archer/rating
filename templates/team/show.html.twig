{% extends 'base.html.twig' %}

{% block title %}{{ team.name }} — Команди — Rating{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">Головна</a><span><a href="{{ path('team_index') }}">Команди</a></span><span>{{ team.name }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ team.id }} — {{ team.name }} ({{ team.townName }})</h1>

    {% if team.squads is not empty %}
        <div class="card">
            <h2>Базові склади</h2>
            <dl>
                {% for squad in team.squads %}
                    <dt>{{ squad.seasonName }}</dt>
                    <dd>
                        {% for player in squad.players %}
                            <a href="{{ path('player_show', {id: player.playerId}) }}">{{ player.playerName }}</a>{% if player.isCaptain %} <span class="captain">(к)</span>{% endif %}<br>
                        {% endfor %}
                    </dd>
                {% endfor %}
            </dl>
        </div>
    {% endif %}

    {% if team.tournamentCount > 0 %}
        <turbo-frame id="team-tournaments" src="{{ path('team_tournaments', {id: team.id}) }}">
            <p>Завантаження турнірів…</p>
        </turbo-frame>
    {% endif %}
{% endblock %}
