{% extends 'base.html.twig' %}

{% block title %}{{ team.name }} — {{ 'nav.teams'|trans }} — {{ 'site.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <nav class="breadcrumbs"><a href="{{ path('home') }}">{{ 'nav.home'|trans }}</a><span><a href="{{ path('team_index') }}">{{ 'nav.teams'|trans }}</a></span><span>{{ team.name }}</span></nav>
{% endblock %}

{% block body %}
    <h1>{{ team.name }} ({{ team.townName }})</h1>

    {% if team.squads is not empty %}
        <div class="card">
            <h2>{{ 'team.base_squads'|trans }}</h2>
            <dl>
                {% for squad in team.squads %}
                    <dt>{{ squad.seasonName }}</dt>
                    <dd>
                        {% for player in squad.players %}
                            {{ include('_player_link.html.twig', {playerId: player.playerId, playerName: player.playerName, hasUser: player.hasUser}, with_context: false) }}{% if player.isCaptain %} <span class="captain">(к)</span>{% endif %}<br>
                        {% endfor %}
                    </dd>
                {% endfor %}
            </dl>
        </div>
    {% endif %}

    {% if team.tournamentCount > 0 %}
        <turbo-frame id="team-tournaments" src="{{ path('team_tournaments', {id: team.id}) }}">
            <p>{{ 'common.loading_tournaments'|trans }}</p>
        </turbo-frame>
    {% endif %}
{% endblock %}
