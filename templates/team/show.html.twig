{% extends 'base.html.twig' %}

{% block title %}{{ team.name }} — Rating{% endblock %}

{% block body %}
    <h1>{{ team.id }} — {{ team.name }} ({{ team.townName }})</h1>

    {% if team.squads is not empty %}
        <div class="card">
            <h2>Базові склади</h2>
            <dl>
                {% for squad in team.squads %}
                    <dt>{{ squad.seasonName }}</dt>
                    <dd>
                        {% for player in squad.players %}
                            <a href="{{ path('player_show', {id: player.playerId}) }}">{{ player.playerName }}</a>{% if player.isCaptain %} <span class="captain">(к)</span>{% endif %}<br>
                        {% endfor %}
                    </dd>
                {% endfor %}
            </dl>
        </div>
    {% endif %}

    {% if team.tournaments is not empty %}
        <div class="card card-wide">
            <h2>Турніри</h2>
            <table>
                <thead>
                    <tr>
                        <th></th>
                        <th>Турнір</th>
                        <th>Дата</th>
                        <th>Склад</th>
                        <th>Місце</th>
                        <th>Результат</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in team.tournaments %}
                        <tr class="{{ loop.index is odd ? 'row-light' : 'row-dark' }}">
                            <td>{{ loop.index }}</td>
                            <td><a href="{{ path('tournament_show', {id: entry.tournamentId}) }}">{{ entry.tournamentName }}</a></td>
                            <td>{{ entry.playedAt ? entry.playedAt|date('d.m.Y') : '—' }}</td>
                            <td>
                                {% for player in entry.players %}
                                    <a href="{{ path('player_show', {id: player.playerId}) }}">{{ player.playerName }}</a>{% if player.isLegionary %} <em>(л)</em>{% endif %}<br>
                                {% endfor %}
                            </td>
                            <td>{{ entry.place ? (entry.place == entry.place|round(0) ? entry.place|number_format(0) : entry.place) : '—' }}</td>
                            <td>{{ entry.score ?? '—' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
